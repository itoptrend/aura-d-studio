// Aura-D Studio — Prisma schema (Phase 1 starter slice)
//
// This is a FOCUSED SUBSET of the full database design in
// Aura-D_Studio_Schema.sql — only the tables needed to get the SEO Article
// module working end-to-end (auth → Connected AI → run → asset). As more
// Phase 1 modules get built, port over more tables from the full schema.sql
// the same way: keep field names/types identical so the two stay compatible.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection — used by the running app
  directUrl = env("DIRECT_URL") // direct (non-pooled) connection — used only for migrations
}

// ---------------------------------------------------------------------------
// TEAM / USER (spec §13.1, simplified — single-owner team for Phase 1)
// ---------------------------------------------------------------------------

model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  members     TeamMember[]
  credentials Credential[]
  workflows   Workflow[]
  assets      Asset[]
  characters  Character[]
  videoJobs   VideoJob[]

  @@map("team")
}

model AppUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")

  memberships TeamMember[]

  @@map("app_user")
}

model TeamMember {
  id     String @id @default(uuid())
  teamId String @map("team_id")
  userId String @map("user_id")
  role   String @default("owner") // 'owner' | 'editor' | 'viewer' — kept simple for Phase 1

  team Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_member")
}

// ---------------------------------------------------------------------------
// AI PROVIDER REGISTRY (spec §5)
// ---------------------------------------------------------------------------

model AiProvider {
  code          String  @id // e.g. 'anthropic', 'openai'
  displayName   String  @map("display_name")
  capabilities  String[] // subset of: text, vision, video, audio, image
  keyPrefixHint String? @map("key_prefix_hint") // used for the Auto-Detection Flow, §5.2
  isActive      Boolean @default(true) @map("is_active")

  models      AiModel[]
  credentials Credential[]

  @@map("ai_provider")
}

model AiModel {
  id           String  @id @default(uuid())
  providerCode String  @map("provider_code")
  modelCode    String  @map("model_code") // e.g. 'claude-sonnet-4-6'
  displayName  String  @map("display_name")
  capability   String  @default("text") // 'text' | 'image' | 'video' | 'audio'
  isActive     Boolean @default(true) @map("is_active")

  provider       AiProvider      @relation(fields: [providerCode], references: [code])
  nodeExecutions NodeExecution[]

  @@unique([providerCode, modelCode])
  @@map("ai_model")
}

enum CredentialStatus {
  active
  expired
  invalid
  rate_limited
  revoked
}

model Credential {
  id              String           @id @default(uuid())
  teamId          String           @map("team_id")
  providerCode    String           @map("provider_code")
  displayName     String           @map("display_name")
  encryptedKey    Bytes            @map("encrypted_key") // AES-256-GCM ciphertext, see src/lib/encryption.ts
  encryptionIv    Bytes            @map("encryption_iv")
  isFreeTier      Boolean          @default(false) @map("is_free_tier") // §5.7.1
  capabilities    String[]
  status          CredentialStatus @default(active)
  lastVerifiedAt  DateTime?        @map("last_verified_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  team           Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  provider       AiProvider      @relation(fields: [providerCode], references: [code])
  nodeExecutions NodeExecution[]
  videoJobs      VideoJob[]

  @@unique([teamId, providerCode, displayName])
  @@map("credential")
}

// ---------------------------------------------------------------------------
// WORKFLOW / RUN (spec §3, §13 — minimal version: one node per run for now)
// ---------------------------------------------------------------------------

model Workflow {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  name      String
  category  String // 'seo_article' for this slice; matches workflow_template.category convention
  createdAt DateTime @default(now()) @map("created_at")

  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  runs Run[]

  @@map("workflow")
}

enum RunStatus {
  pending
  running
  succeeded
  failed
}

model Run {
  id         String    @id @default(uuid())
  workflowId String    @map("workflow_id")
  status     RunStatus @default(pending)
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  workflow       Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeExecutions NodeExecution[]
  assets         Asset[]

  @@map("run")
}

enum NodeExecStatus {
  pending
  running
  succeeded
  failed
}

model NodeExecution {
  id              String         @id @default(uuid())
  runId           String         @map("run_id")
  taskName        String         @map("task_name") // human-readable step label, e.g. "เขียนบทความ SEO"
  status          NodeExecStatus @default(pending)
  credentialId    String?        @map("credential_id")
  resolvedModelId String?        @map("resolved_model_id") // §4.6.1 Generation Recipe — actual model used
  inputJson       Json?          @map("input_json")
  outputJson      Json?          @map("output_json")
  costCredit      Decimal        @default(0) @map("cost_credit") @db.Decimal(10, 4)
  errorMessage    String?        @map("error_message")
  startedAt       DateTime?      @map("started_at")
  finishedAt      DateTime?      @map("finished_at")

  run             Run         @relation(fields: [runId], references: [id], onDelete: Cascade)
  credential      Credential? @relation(fields: [credentialId], references: [id])
  resolvedModel   AiModel?    @relation(fields: [resolvedModelId], references: [id])
  assets          Asset[]

  @@map("node_execution")
}

// ---------------------------------------------------------------------------
// CHARACTER ENGINE (spec §7 Character Engine)
// ---------------------------------------------------------------------------

model Character {
  id          String   @id @default(uuid())
  teamId      String   @map("team_id")
  name        String                          // ชื่อตัวละคร เช่น "น้องออร่า"
  description String?                         // คำอธิบายสั้นๆ
  role        String   @default("unset")      // 'heroine' | 'hero' | 'supporting' | 'extra' | 'villain' | 'unset'
  personality String   @default("")           // บุคลิกนิสัย
  tone        String   @default("")           // น้ำเสียงการสื่อสาร
  backstory   String?                         // ประวัติ/เรื่องราว
  examples    String?                         // ตัวอย่างประโยคที่ตัวละครจะพูด
  avatarEmoji String   @default("🤖") @map("avatar_emoji")

  // รูปลักษณ์ — ใช้ล็อกหน้าตาให้ตัวละครออกมาใกล้เคียงกันทุกฉาก/ทุก EP
  gender      String   @default("")           // เพศ เช่น หญิง/ชาย/ไม่ระบุ
  ageRange    String   @default("") @map("age_range")   // ช่วงวัย เช่น "25-30 ปี"
  skinTone    String   @default("") @map("skin_tone")   // สีผิว เช่น "ผิวสองสี"
  hairStyle   String   @default("") @map("hair_style")  // ทรงผม เช่น "ผมยาวสีดำตรง"
  faceDetails String   @default("") @map("face_details") // หน้าตา เช่น "หน้ารูปไข่ ตากลมโต ยิ้มมีลักยิ้ม"
  bodyType    String   @default("") @map("body_type")   // รูปร่าง เช่น "สมาร์ทหุ่นดี / ท้วม / มีกล้าม"
  height      String   @default("")                     // ส่วนสูง เช่น "สูง 165 ซม."
  distinctive String   @default("")                     // จุดเด่น เช่น "มีไฝใต้ตา ใส่แว่น"
  appearance  String?                          // (เก่า) หน้าตารวม — เก็บไว้เผื่อข้อมูลเดิม
  outfit      String?                          // ชุด/สไตล์ประจำตัว
  portraitUrl String?  @map("portrait_url")    // ภาพตัวละคร (data URL) — เก็บถาวรจนกว่าจะลบเอง

  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("character")
}

// ---------------------------------------------------------------------------
// SKILL LIBRARY (spec §18.9 Official Skill Library)
// ---------------------------------------------------------------------------

model Skill {
  id             String   @id @default(uuid())
  name           String
  description    String
  category       String   // 'seo' | 'social' | 'character' | 'video' | 'general'
  promptTemplate String   @map("prompt_template") // system prompt template
  isOfficial     Boolean  @default(false) @map("is_official") // true = Aura-D platform skill (read-only)
  isActive       Boolean  @default(true) @map("is_active")
  teamId         String?  @map("team_id") // null = official skill, set = custom team skill
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([name, category, teamId], name: "name_category_team")
  @@map("skill")
}

// ---------------------------------------------------------------------------
// ASSET (spec §13, §4.6 Generation Recipe & Favorites)
// ---------------------------------------------------------------------------

enum AssetType {
  image
  video
  audio
  document
  storyboard
}

model Asset {
  id                    String    @id @default(uuid())
  teamId                String    @map("team_id")
  type                  AssetType
  title                 String
  contentText           String?   @map("content_text")      // document / text content
  fileUrl               String?   @map("file_url")          // Vercel Blob URL — video, audio, image (Phase 3+)
  thumbnailUrl          String?   @map("thumbnail_url")     // optional poster frame for video assets
  sourceNodeExecutionId String?   @map("source_node_execution_id")
  sourceRunId           String?   @map("source_run_id")
  isFavorited           Boolean   @default(false) @map("is_favorited")
  favoritedAt           DateTime? @map("favorited_at")
  expiresAt             DateTime? @map("expires_at")          // null = เก็บถาวร
  createdAt             DateTime  @default(now()) @map("created_at")

  team                Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sourceNodeExecution NodeExecution? @relation(fields: [sourceNodeExecutionId], references: [id])
  sourceRun           Run?           @relation(fields: [sourceRunId], references: [id])

  @@index([expiresAt])
  @@map("asset")
}

// ---------------------------------------------------------------------------
// VIDEO JOB — async generation queue (Phase 3)
// ---------------------------------------------------------------------------

enum VideoJobStatus {
  pending    // รอ worker หยิบไปทำ
  running    // กำลังสร้างวิดีโอที่ provider
  succeeded  // เสร็จแล้ว blobUrl พร้อมใช้
  failed     // ล้มเหลวหลัง retry ครบ
  stalled    // ค้างนานเกิน 15 นาที — cron จะ re-queue
  cancelled  // user ยกเลิก
}

model VideoJob {
  id             String         @id @default(uuid())
  teamId         String         @map("team_id")
  provider       String         // 'google' | 'kling' | 'runway'
  modelCode      String         @map("model_code")           // e.g. 'veo-3.0-generate-preview'
  prompt         String                                       // prompt ที่ส่งไป provider
  negativePrompt String?        @map("negative_prompt")
  durationSecs   Int            @default(8) @map("duration_secs")
  aspectRatio    String         @default("16:9") @map("aspect_ratio") // '16:9' | '9:16' | '1:1'
  credentialId   String?        @map("credential_id")        // Credential ที่ใช้

  // สำหรับงาน Lip Sync (modelCode: 'kling-lip-sync')
  inputVideoUrl  String?        @map("input_video_url")      // วิดีโอต้นทางที่จะขยับปาก
  inputAudioUrl  String?        @map("input_audio_url")      // ไฟล์เสียงพูด (โหมด audio)

  status         VideoJobStatus @default(pending)
  attempts       Int            @default(0)                  // จำนวนครั้งที่ลองแล้ว
  maxAttempts    Int            @default(3) @map("max_attempts")
  providerJobId  String?        @map("provider_job_id")      // operation name จาก Veo / task id จาก Kling
  blobUrl        String?        @map("blob_url")             // Vercel Blob URL เมื่อสำเร็จ
  assetId        String?        @map("asset_id")             // Asset ที่ถูกสร้างเมื่อสำเร็จ
  errorMessage   String?        @map("error_message")
  errorCode      String?        @map("error_code")           // 'content_policy' | 'timeout' | 'api_error'

  stalledAt      DateTime?      @map("stalled_at")           // เวลาที่ detect ว่า stalled
  startedAt      DateTime?      @map("started_at")
  finishedAt     DateTime?      @map("finished_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  team           Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  credential     Credential?    @relation(fields: [credentialId], references: [id])

  @@index([teamId, status])     // query งานของ team ตาม status
  @@index([status, createdAt])  // cron หยิบงาน pending เรียงตามเวลา
  @@map("video_job")
}
