# Copy this file to .env and fill in real values before running the app.
# Never commit the real .env file.

# --- Local development (docker-compose) ---
# DATABASE_URL="postgresql://auradb:auradb_local_dev@localhost:5432/aura_d_studio?schema=public"
# DIRECT_URL="postgresql://auradb:auradb_local_dev@localhost:5432/aura_d_studio?schema=public"

# --- Production (e.g. Neon free tier) ---
# Neon gives you TWO connection strings — paste the pooled one into
# DATABASE_URL (what the running app uses) and the direct one into
# DIRECT_URL (what `prisma migrate` uses). Both come from the same
# Neon project dashboard, no extra setup needed.
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-base64-string"
# Local dev: http://localhost:3000 — Production: your real deployed URL
# (Vercel sets this automatically via VERCEL_URL, but setting it explicitly
# avoids surprises — use your actual https://your-app.vercel.app URL)
NEXTAUTH_URL="http://localhost:3000"

# AES-256-GCM key used ONLY to encrypt/decrypt each user's own AI provider
# API keys before storing them in the `credential` table (spec §5.3).
# Generate with: openssl rand -base64 32
# In production this MUST come from a real secrets manager (AWS Secrets
# Manager / HashiCorp Vault per spec §15), not a plain .env file.
CREDENTIAL_ENCRYPTION_KEY="replace-with-a-random-32-byte-base64-string"
